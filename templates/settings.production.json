{
  "_comment": "Production settings — tighter permissions. Copy to .claude/settings.json and customize.",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(git *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(curl *)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(trash *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(bun *)",
      "Bash(systemctl --user *)",
      "Bash(crontab *)",
      "Bash(tmux *)",
      "Read(*)",
      "Write(~/.claude-agent/*)",
      "Write(~/projects/*)",
      "Write(/tmp/*)",
      "Edit(~/.claude-agent/*)",
      "Edit(~/projects/*)",
      "Grep(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Write(/etc/*)",
      "Write(/usr/*)",
      "Edit(/etc/*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude-agent/scripts/session-init.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\" && git add -A 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude-agent/scripts/session-shutdown.sh"
          }
        ]
      }
    ]
  }
}
